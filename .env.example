# SGO environment variables.
# Copy to `.env` and fill in. EXPO_PUBLIC_* vars are bundled into the client.
# Firebase web keys are not secret; access is controlled by Security Rules.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps keys are configured natively in app.json (ios/android config).
# Keep platform-restricted keys; do not reuse the Firebase key here.
